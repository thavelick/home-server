[Unit]
Description=Restart Home Assistant once DNS is reachable (recover from boot race)
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/sh -c 'for i in $(seq 1 60); do getent hosts home-assistant.io >/dev/null && exit 0; sleep 2; done; echo "DNS never came up" >&2; exit 1'
ExecStart=/usr/bin/docker restart homeassistant

[Install]
WantedBy=multi-user.target
